{% extends 'base.html' %}
{% block content %}
<h1>Checklist de compras - Evento {{ evento_id }}</h1>
<p>Seleccione artículos y marque cantidad comprada.</p>

<table class="table">
  <thead><tr><th>Artículo</th><th>Saldo</th><th>Cantidad</th><th>Paquetes</th><th></th></tr></thead>
  <tbody>
    {% for it in lista %}
    <tr>
      <td>{{ it.nombre }}</td>
      <td>{{ it.resta }}</td>
      <td>
        <form method="post" action="/eventos/{{ evento_id }}/mark_purchased" style="display:inline-block" id="form-{{ it.articulo_id }}" onsubmit="return checkQuantity(this, {{ it.resta }})">
          <input type="hidden" name="articulo_id" value="{{ it.articulo_id }}">
          <input type="number" name="cantidad" step="any" min="0" class="form-control d-inline-block" style="width:120px; display:inline-block" value="{{ it.resta }}" id="cant-{{ it.articulo_id }}" oninput="updatePaquetes({{ it.articulo_id }})">
      </td>
      <td>
          <span id="paq-{{ it.articulo_id }}">0</span>
      </td>
      <td>
          <button type="submit" class="btn btn-sm btn-primary ms-2">Compré</button>
        </form>
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>

<script>
  // mapa articulo_id -> unidad_compra
  const unidadMap = {
    {% for a in articulos %}
      {{ a.id }}: {{ a.unidad_compra or 1 }},{% endfor %}
  };

  function updatePaquetes(artId){
    const input = document.getElementById('cant-' + artId);
    if (!input) return;
    let q = parseFloat(input.value || 0);
    if (isNaN(q)) q = 0;
    const unidad = parseFloat(unidadMap[artId] || 1) || 1;
    const paquetes = q / unidad;
    const disp = document.getElementById('paq-' + artId);
    if (disp) disp.textContent = paquetes.toFixed(2);
  }

  // inicializar paquetes visibles
  document.addEventListener('DOMContentLoaded', function(){
    {% for it in lista %}
      updatePaquetes({{ it.articulo_id }});
    {% endfor %}
  });
</script>

<script>
function checkQuantity(form, max){
  const input = form.querySelector('input[name="cantidad"]');
  if (!input) return true;
  let q = input.value ? input.value.toString().replace(',', '.') : '0';
  let val = parseFloat(q);
  if (isNaN(val) || val <= 0){
    alert('Cantidad inválida');
    return false;
  }
  if (val > parseFloat(max)){
    return confirm('La cantidad ingresada (' + val + ') excede el saldo (' + max + '). Desea continuar?');
  }
  return true;
}
</script>
</script>

<a href="/eventos/{{ evento_id }}" class="btn btn-secondary">Volver al evento</a>
{% endblock %}
