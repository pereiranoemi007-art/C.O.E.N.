{% extends 'base.html' %}
{% block content %}
<h1>Editar línea de compra</h1>
<form method="post">
  <div class="mb-3">
    <label class="form-label">Artículo</label>
    <input class="form-control" value="{{ articulo.nombre if articulo else '' }}" disabled>
  </div>
  <div class="mb-3">
    <label class="form-label">Cantidad</label>
    <input class="form-control" value="{{ line.cantidad }}" disabled>
  </div>
  <div class="mb-3">
    <label class="form-label">Precio unit</label>
    <input name="precio_unit" class="form-control" value="{{ line.precio_unit }}">
  </div>
  <button class="btn btn-primary">Guardar</button>
</form>
{% endblock %}
