@app.route('/eventos/reporte_presupuesto/<int:evento_id>')
def reporte_presupuesto(evento_id):
    if SimpleDocTemplate is None:
        flash('reportlab no está instalado')
        return redirect('/eventos')

    evento = db.fetchone('SELECT nombre, cantidad_personas, tipo_actividad FROM Eventos WHERE id=?', (evento_id,))
    nombre = evento['nombre'] if evento else f'evento_{evento_id}'
    personas = int(evento.get('cantidad_personas') or 0) if evento else 0
    tipo = (evento.get('tipo_actividad') or '').strip().lower()

    rows = db.fetchall('''
        SELECT 
            COALESCE(ed.momento, 'Sin momento') AS momento,
            a.nombre,
            a.precio,
            a.unidad_compra,
            SUM(cd.cant_jov) AS sum_jov,
            SUM(cd.cant_dor) AS sum_dor,
            SUM(cd.cant_var) AS sum_var
        FROM EventoDetalle ed
        JOIN ComidaDetalle cd ON ed.comida_id = cd.comida_id
        JOIN Articulos a ON cd.articulo_id = a.id
        WHERE ed.evento_id = ?
        GROUP BY momento, a.id
        ORDER BY momento
    ''', (evento_id,))

    buf = io.BytesIO()
    doc = SimpleDocTemplate(buf)
    styles = getSampleStyleSheet()

    elements = [Paragraph(f"Presupuesto estimado - {nombre}", styles['Title'])]

    data = [["Momento", "Artículo", "Cantidad Final", "Precio Unit", "Subtotal"]]

    total_general = 0
    totales_por_momento = {}

    for r in rows:
        # 🔥 elegir tipo correcto
        if tipo.startswith('dor'):
            per = r['sum_dor'] or 0
        elif tipo.startswith('jov'):
            per = r['sum_jov'] or 0
        elif tipo.startswith('var'):
            per = r['sum_var'] or 0
        else:
            per = (r['sum_jov'] or 0) + (r['sum_dor'] or 0) + (r['sum_var'] or 0)

        # 🔥 convertir unidad a número
        try:
            unidad = float(r['unidad_compra']) if r['unidad_compra'] else 1
        except:
            unidad = 1

        precio = float(r['precio'] or 0)

        # 🔥 FORMULA CLAVE
        cantidad_final = (per * personas) / unidad
        subtotal = cantidad_final * precio

        total_general += subtotal

        momento = r['momento']
        if momento not in totales_por_momento:
            totales_por_momento[momento] = 0
        totales_por_momento[momento] += subtotal

        data.append([
            momento,
            r['nombre'],
            f"{cantidad_final:.2f}",
            f"{precio:.2f}",
            f"{subtotal:.2f}"
        ])

    # ======================
    # Incluir gastos generales (artículos) vinculados al evento en el presupuesto
    gasto_articulos = db.fetchall('''
        SELECT COALESCE(eg.momento, 'Sin momento') AS momento,
               a.nombre, a.precio, a.unidad_compra,
               gd.cant_jov, gd.cant_dor, gd.cant_var
        FROM EventoGasto eg
        JOIN GastoDetalle gd ON eg.gasto_id = gd.gasto_id
        JOIN Articulos a ON gd.articulo_id = a.id
        WHERE eg.evento_id = ?
    ''', (evento_id,))

    for r in gasto_articulos:
        if tipo.startswith('dor'):
            per = r.get('cant_dor') or 0
        elif tipo.startswith('jov'):
            per = r.get('cant_jov') or 0
        elif tipo.startswith('var'):
            per = r.get('cant_var') or 0
        else:
            per = (r.get('cant_jov') or 0) + (r.get('cant_dor') or 0) + (r.get('cant_var') or 0)

        try:
            unidad = float(r['unidad_compra']) if r.get('unidad_compra') else 1
        except Exception:
            unidad = 1
        precio = float(r.get('precio') or 0)

        cantidad_final = (per * personas) / (unidad if unidad else 1)
