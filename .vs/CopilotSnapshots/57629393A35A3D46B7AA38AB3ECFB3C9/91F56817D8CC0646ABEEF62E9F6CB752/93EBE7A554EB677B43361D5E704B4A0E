@app.route('/eventos/<int:evento_id>')
def evento_detail(evento_id):
    evento = db.fetchone('SELECT * FROM Eventos WHERE id=?', (evento_id,))
    if not evento:
        flash('Evento no encontrado')
        return redirect('/eventos')

    # comidas disponibles y comidas vinculadas
    comidas = db.fetchall('SELECT id, descripcion FROM Comidas')
    vinculadas = db.fetchall('''
        SELECT ed.id as detalle_id, c.id as comida_id, c.descripcion
        FROM EventoDetalle ed
        JOIN Comidas c ON ed.comida_id = c.id
        WHERE ed.evento_id=?
    ''', (evento_id,))

    # gastos disponibles y gastos vinculados
    gastos = db.fetchall('SELECT id, descripcion FROM Gastos')
    vinculadas_gastos = db.fetchall('''
        SELECT eg.id as evento_gasto_id, g.id as gasto_id, g.descripcion, eg.momento, eg.monto_manual
        FROM EventoGasto eg
        JOIN Gastos g ON eg.gasto_id = g.id
        WHERE eg.evento_id = ?
    ''', (evento_id,))

    return render_template('eventos_detail.html', evento=evento, comidas=comidas, vinculadas=vinculadas, gastos=gastos, vinculadas_gastos=vinculadas_gastos)


