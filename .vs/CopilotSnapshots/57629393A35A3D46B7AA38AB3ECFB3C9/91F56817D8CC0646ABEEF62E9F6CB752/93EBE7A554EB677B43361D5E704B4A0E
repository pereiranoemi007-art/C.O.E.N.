@app.route('/eventos/reporte_compras/<int:evento_id>')
def reporte_compras(evento_id):
    if SimpleDocTemplate is None:
        flash('reportlab no está instalado')
        return redirect('/eventos')
    evento = db.fetchone('SELECT nombre, cantidad_personas, tipo_actividad FROM Eventos WHERE id=?', (evento_id,))
    nombre = evento['nombre'] if evento else f'evento_{evento_id}'
    personas = int(evento.get('cantidad_personas') or 0) if evento else 0
    tipo = (evento.get('tipo_actividad') or '').strip().lower() if evento else ''

    # sumar por artículo las cantidades por comida vinculada (separado por grupo)
    rows = db.fetchall('''
        SELECT a.nombre,
               SUM(cd.cant_jov) AS sum_jov,
               SUM(cd.cant_dor) AS sum_dor,
               SUM(cd.cant_var) AS sum_var
        FROM EventoDetalle ed
        JOIN ComidaDetalle cd ON ed.comida_id = cd.comida_id
        JOIN Articulos a ON cd.articulo_id = a.id
        WHERE ed.evento_id=?
        GROUP BY a.nombre
    ''', (evento_id,))

    buf = io.BytesIO()
    doc = SimpleDocTemplate(buf)
    styles = getSampleStyleSheet()
    elements = [Paragraph(f"Reporte de Compras - {nombre}", styles['Title'])]

    data = [["Artículo", "Cantidad"]]
    for r in rows:
        # elegir columna según tipo de evento
        if tipo.startswith('dor'):
            per = r.get('sum_dor') or 0
        elif tipo.startswith('jov'):
            per = r.get('sum_jov') or 0
        elif tipo.startswith('var'):
            per = r.get('sum_var') or 0
        else:
            per = (r.get('sum_jov') or 0) + (r.get('sum_dor') or 0) + (r.get('sum_var') or 0)

        total = per * personas
        data.append([r['nombre'], f"{total:.2f}"])

    table = Table(data)
    table.setStyle([('GRID', (0, 0), (-1, -1), 1, colors.black)])
    elements.append(table)
    doc.build(elements)
    buf.seek(0)
    safe = re.sub(r'[^a-zA-Z0-9_ ]', '', nombre).replace(' ', '_')
    return send_file(buf, mimetype='application/pdf', as_attachment=True, download_name=f'Compras_{safe}.pdf')


@app.route('/eventos/reporte_saldo/<int:evento_id>')
def reporte_saldo(evento_id):
    if SimpleDocTemplate is None:
        flash('reportlab no está instalado')
        return redirect('/eventos')
    evento = db.fetchone('SELECT nombre, cantidad_personas, tipo_actividad FROM Eventos WHERE id=?', (evento_id,))
    nombre = evento['nombre'] if evento else f'evento_{evento_id}'
    personas = int(evento.get('cantidad_personas') or 0) if evento else 0
    tipo = (evento.get('tipo_actividad') or '').strip().lower()

    # sumar por artículo las cantidades por comida vinculada
    sums = db.fetchall('''
        SELECT a.id AS articulo_id, a.nombre AS articulo,
               SUM(cd.cant_jov) AS sum_jov,
               SUM(cd.cant_dor) AS sum_dor,
               SUM(cd.cant_var) AS sum_var
        FROM EventoDetalle ed
        JOIN ComidaDetalle cd ON ed.comida_id = cd.comida_id
        JOIN Articulos a ON cd.articulo_id = a.id
        WHERE ed.evento_id = ?
        GROUP BY a.id, a.nombre
    ''', (evento_id,))

    necesarios = []
    for s in sums:
        if tipo.startswith('dor'):
            per_person = float(s.get('sum_dor') or 0)
        elif tipo.startswith('jov'):
            per_person = float(s.get('sum_jov') or 0)
        elif tipo.startswith('var'):
            per_person = float(s.get('sum_var') or 0)
        else:
            per_person = float((s.get('sum_jov') or 0) + (s.get('sum_dor') or 0) + (s.get('sum_var') or 0))

        necesario_total = per_person * personas
        necesarios.append({'articulo_id': s['articulo_id'], 'nombre': s['articulo'], 'necesario': necesario_total})

    # comprados por artículo
    comprados = db.fetchall('''
        SELECT cd.articulo_id, SUM(cd.cantidad) as total
        FROM CompraDetalle cd
        JOIN Compras c ON cd.compra_id = c.id
        WHERE c.evento_id=?
        GROUP BY cd.articulo_id
    ''', (evento_id,))
    comprados_dict = {c['articulo_id']: c['total'] for c in comprados}

    # construir PDF
    buf = io.BytesIO()
    doc = SimpleDocTemplate(buf)
    styles = getSampleStyleSheet()
    elements = [Paragraph(f"Reporte de Saldo - {nombre}", styles['Title'])]

    data = [["Artículo", "Necesario", "Comprado", "Saldo"]]
    for it in necesarios:
        comprado = float(comprados_dict.get(it['articulo_id']) or 0)
        saldo = (it['necesario'] or 0) - comprado
        data.append([it['nombre'], f"{it['necesario']:.2f}", f"{comprado:.2f}", f"{saldo:.2f}"])

    table = Table(data)
    table.setStyle([('GRID', (0, 0), (-1, -1), 1, colors.black)])
    elements.append(table)
    doc.build(elements)
    buf.seek(0)
    safe = re.sub(r'[^a-zA-Z0-9_ ]', '', nombre).replace(' ', '_')
    return send_file(buf, mimetype='application/pdf', as_attachment=True, download_name=f'Saldo_{safe}.pdf')

