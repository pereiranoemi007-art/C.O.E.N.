{% extends 'base.html' %}
{% block content %}
<h1>Evento: {{ evento.nombre }}</h1>
<p>Personas: {{ evento.cantidad_personas }} - Tipo: {{ evento.tipo_actividad }} - {% if evento.closed %}CERRADO{% else %}ABIERTO{% endif %}</p>

<div class="row">
  <div class="col-md-6">
    <h4>Comidas disponibles</h4>
    <form method="post" action="/eventos/{{ evento.id }}/add_comida">
      <div class="input-group mb-3">
        <select name="comida_id" class="form-select" {% if evento.closed %} disabled {% endif %}>
          <option value="">Seleccione comida</option>
          {% for c in comidas %}
          <option value="{{ c.id }}">{{ c.descripcion }}</option>
          {% endfor %}
        </select>
        <input name="momento" placeholder="ej: Viernes Cena)" class="form-control" {% if evento.closed %} disabled {% endif %} />
        <button class="btn btn-primary" type="submit" {% if evento.closed %} disabled {% endif %}>Agregar a evento</button>
      </div>
    </form>
  </div>

  <div class="col-md-6">
    <h4>Compra rápida (BORRADOR)</h4>
    <form method="post" action="/eventos/{{ evento.id }}/quick_add" class="d-flex">
      <select name="articulo_id" class="form-select me-2">
        <option value="">Artículo</option>
        {% for a in articulos %}
        <option value="{{ a.id }}">{{ a.nombre }}</option>
        {% endfor %}
      </select>
      <input name="cantidad" class="form-control me-2" placeholder="Cantidad">
      <button class="btn btn-outline-primary">Agregar</button>
    </form>
    <div class="mt-2">
      <a href="/compras?evento={{ evento.id }}" class="btn btn-sm btn-success">Ir a Compras (confirmar)</a>
    </div>
  </div>

  <div class="col-md-6">
    <h4>Comidas vinculadas</h4>
    <table class="table table-sm">
      <thead><tr><th>ID</th><th>Comida</th><th></th></tr></thead>
      <tbody>
        {% for v in vinculadas %}
        <tr>
          <td>{{ v.comida_id }}</td>
          <td>{{ v.descripcion }}</td>
          <td>
            <a class="btn btn-sm btn-danger" href="/eventos/{{ evento.id }}/remove_comida/{{ v.detalle_id }}" {% if evento.closed %} onclick="alert('Evento cerrado'); return false;" {% endif %}>Quitar</a>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

<hr>
<div class="row">
  <div class="col-md-6">
    <h4>Gastos disponibles</h4>
    <form method="post" action="/eventos/{{ evento.id }}/add_gasto">
      <div class="input-group mb-3">
        <select name="gasto_id" class="form-select" {% if evento.closed %} disabled {% endif %}>
          <option value="">Seleccione gasto</option>
          {% for g in gastos %}
          <option value="{{ g.id }}">{{ g.descripcion }}</option>
          {% endfor %}
        </select>
        <button class="btn btn-primary" type="submit" {% if evento.closed %} disabled {% endif %}>Agregar gasto</button>
      </div>
    </form>
  </div>

  <div class="col-md-6">
    <h4>Gastos vinculados</h4>
    <table class="table table-sm">
      <thead><tr><th>ID</th><th>Gasto</th><th>Momento</th><th>Monto manual</th><th></th></tr></thead>
      <tbody>
        {% for vg in vinculadas_gastos %}
        <tr>
          <td>{{ vg.gasto_id }}</td>
          <td>{{ vg.descripcion }}</td>
          <td>{{ vg.momento or 'Sin momento' }}</td>
          <td>{{ vg.monto_manual or '' }}</td>
          <td>
            <a class="btn btn-sm btn-danger" href="/eventos/{{ evento.id }}/remove_gasto/{{ vg.evento_gasto_id }}" {% if evento.closed %} onclick="alert('Evento cerrado'); return false;" {% endif %}>Quitar</a>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

{% endblock %}