{% extends 'base.html' %}
{% block content %}
<h1>Detalle Gasto: {{ gasto.descripcion or gasto.nombre }}</h1>

<form method="post" action="/gastos/{{ gasto.id }}/add_line">
  <div class="row">
    <div class="col-md-6">
      <label class="form-label">Artículo</label>
      <select name="articulo_id" class="form-select">
        <option value="">--Seleccione--</option>
        {% for a in articulos %}
        <option value="{{ a.id }}">{{ a.nombre }}</option>
        {% endfor %}
      </select>
    </div>
    <div class="col-md-2">
      <label class="form-label">Jov</label>
      <input name="jov" class="form-control">
    </div>
    <div class="col-md-2">
      <label class="form-label">Dor</label>
      <input name="dor" class="form-control">
    </div>
    <div class="col-md-2">
      <label class="form-label">Var</label>
      <input name="var" class="form-control">
    </div>
  </div>
  <div class="mt-3">
    <button class="btn btn-primary">Agregar línea</button>
  </div>
</form>

<hr>
<h2>Detalle actual</h2>
<table class="table">
  <thead><tr><th>Artículo</th><th>Jov</th><th>Dor</th><th>Var</th><th>Acciones</th></tr></thead>
  <tbody>
    {% for d in detalle %}
    <tr>
      <td>{{ d.nombre }}</td>
      <td>{{ d.cant_jov }}</td>
      <td>{{ d.cant_dor }}</td>
      <td>{{ d.cant_var }}</td>
      <td><a href="/gastos/{{ gasto.id }}/delete_line/{{ d.id }}" class="btn btn-sm btn-danger">Eliminar</a></td>
    </tr>
    {% endfor %}
  </tbody>
</table>

<hr>
<h3>Vincular a evento</h3>
<form method="post" action="/gastos/{{ gasto.id }}/vincular_evento">
  <div class="row">
    <div class="col-md-6">
      <label class="form-label">Evento</label>
      <select name="evento_id" class="form-select">
        {% for ev in eventos %}
        <option value="{{ ev.id }}">{{ ev.nombre }}</option>
        {% endfor %}
      </select>
    </div>
    <div class="col-md-4">
      <label class="form-label">Momento</label>
      <input name="momento" class="form-control">
    </div>
    <div class="col-md-2">
      <label class="form-label">Monto manual (opcional)</label>
      <input name="monto_manual" class="form-control">
    </div>
  </div>
  <div class="mt-3">
    <button class="btn btn-primary">Vincular</button>
  </div>
</form>

{% endblock %}
