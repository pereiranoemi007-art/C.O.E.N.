import tkinter as tk
from tkinter import ttk, messagebox
from database import Database

class EventosWindow(tk.Toplevel):
    def __init__(self, parent):
        super().__init__(parent)
        self.title('Eventos')
        self.geometry('900x600')
        self.db = Database('coen.db')
        self.create_widgets()
        self.load_eventos()
        self.load_comidas()

    def create_widgets(self):
        frm = ttk.Frame(self, padding=10)
        frm.pack(expand=True, fill='both')

        top = ttk.Frame(frm)
        top.pack(fill='x')
        ttk.Label(top, text='Nombre evento:').grid(row=0, column=0)
        self.nombre = ttk.Entry(top)
        self.nombre.grid(row=0, column=1, sticky='ew')
        ttk.Label(top, text='Cantidad personas:').grid(row=1, column=0)
        self.cant_personas = ttk.Entry(top)
        self.cant_personas.grid(row=1, column=1, sticky='ew')
        ttk.Label(top, text='Tipo actividad:').grid(row=2, column=0)
        self.tipo = ttk.Combobox(top, values=['Dorcas', 'Jovenes', 'Varones'])
        self.tipo.grid(row=2, column=1, sticky='ew')
        # closed flag
        self.closed_var = tk.IntVar(value=0)
        self.closed_chk = ttk.Checkbutton(top, text='Evento cerrado', variable=self.closed_var)
        self.closed_chk.grid(row=0, column=2, padx=5)
        self.save_closed_btn = ttk.Button(top, text='Guardar estado', command=self.save_closed_state)
        self.save_closed_btn.grid(row=1, column=2, padx=5)
        top.columnconfigure(1, weight=1)
        ttk.Button(top, text='Agregar Evento', command=self.add_evento).grid(row=0, column=2, rowspan=2, padx=5)

        mid = ttk.Frame(frm)
        mid.pack(fill='both', expand=True, pady=10)

        left = ttk.Frame(mid)
        left.pack(side='left', fill='y')
        cols = ('id', 'nombre', 'cantidad_personas', 'tipo_actividad', 'closed')
        self.tree = ttk.Treeview(left, columns=cols, show='headings', height=15)
        for c in cols:
            self.tree.heading(c, text=c)
        self.tree.pack(side='left')
        self.tree.bind('<<TreeviewSelect>>', self.on_select_evento)

        right = ttk.Frame(mid)
        right.pack(side='left', fill='both', expand=True, padx=10)
        ttk.Label(right, text='Detalle de evento').pack()
        self.detalle_frame = ttk.Frame(right)
        self.detalle_frame.pack(fill='both', expand=True)

        btns = ttk.Frame(frm)
        btns.pack(fill='x')
        self.save_btn = ttk.Button(btns, text='Guardar detalle', command=self.save_detalle)
        self.save_btn.pack(side='left', padx=5)
        self.del_btn = ttk.Button(btns, text='Eliminar evento', command=self.delete_evento)
        self.del_btn.pack(side='left', padx=5)
        ttk.Button(btns, text='Imprimir compras', command=self.imprimir_compras).pack(side='left', padx=5)
        ttk.Button(btns, text='Imprimir saldo', command=self.imprimir_saldo).pack(side='left', padx=5)

        self.detalle_rows = []

    def load_eventos(self):
        for r in self.tree.get_children():
            self.tree.delete(r)
        rows = self.db.fetchall('SELECT id, nombre, cantidad_personas, tipo_actividad, closed FROM Eventos')
        for row in rows:
            self.tree.insert('', 'end', values=(row['id'], row['nombre'], row['cantidad_personas'], row['tipo_actividad'], row['closed']))

    def load_comidas(self):
        self.comidas = self.db.fetchall('SELECT id, descripcion FROM Comidas')

    def add_evento(self):
        nombre = self.nombre.get().strip()
        try:
            cp = int(self.cant_personas.get())
        except ValueError:
            messagebox.showerror('Error', 'Cantidad inválida')
            return
        tipo = self.tipo.get().strip()
        if not nombre or not tipo:
            messagebox.showerror('Error', 'Completar nombre y tipo')
            return
        self.db.execute('INSERT INTO Eventos(nombre, cantidad_personas, tipo_actividad) VALUES(?,?,?)', (nombre, cp, tipo))
        self.load_eventos()

    def on_select_evento(self, event):
        sel = self.tree.selection()
        if not sel:
            return
        vals = self.tree.item(sel[0])['values']
        # vals: id, nombre, cantidad_personas, tipo_actividad, closed
        self.evento_id = vals[0]
        closed = vals[4] if len(vals) > 4 else 0
        self.closed_var.set(closed)
        self.evento_closed = bool(closed)
        self.load_detalle()

    def clear_detalle_ui(self):
        for w in self.detalle_frame.winfo_children():
            w.destroy()
        self.detalle_rows = []

    def load_detalle(self):
        self.clear_detalle_ui()
        rows = self.db.fetchall('SELECT ed.id, ed.comida_id, c.descripcion, ed.momento FROM EventoDetalle ed LEFT JOIN Comidas c ON ed.comida_id=c.id WHERE ed.evento_id=?', (self.evento_id,))
        for r in rows:
            self.add_detalle_row(r['comida_id'], r['descripcion'], r['momento'], existing_id=r['id'])
        self.add_detalle_row()
        # disable editing if event closed
        if getattr(self, 'evento_closed', False):
            for rr in self.detalle_rows:
                rr['combobox']['state'] = 'disabled'
                rr['momento']['state'] = 'disabled'
            try:
                self.save_btn['state'] = 'disabled'
                self.del_btn['state'] = 'disabled'
            except Exception:
                pass

    def add_detalle_row(self, comida_id=None, descripcion='', momento='', existing_id=None):
        row = {}
        frm = ttk.Frame(self.detalle_frame)
        frm.pack(fill='x', pady=2)
        cb = ttk.Combobox(frm, values=[c['descripcion'] for c in self.comidas])
        if comida_id:
            cb.set(descripcion)
        cb.pack(side='left', fill='x', expand=True, padx=2)
        row['combobox'] = cb
        e1 = ttk.Entry(frm, width=20)
        e1.insert(0, momento)
        e1.pack(side='left', padx=2)
        row['momento'] = e1
        btn = ttk.Button(frm, text='X', width=3, command=lambda f=frm: self.remove_detalle_row(f))
        btn.pack(side='left', padx=2)
        row['frame'] = frm
        row['id'] = existing_id
        self.detalle_rows.append(row)
        if getattr(self, 'evento_closed', False):
            row['combobox']['state'] = 'disabled'
            row['momento']['state'] = 'disabled'

    def remove_detalle_row(self, frame):
        for r in list(self.detalle_rows):
            if r['frame'] == frame:
                r['frame'].destroy()
                self.detalle_rows.remove(r)

    def save_detalle(self):
        if not hasattr(self, 'evento_id'):
            messagebox.showwarning('Aviso', 'Seleccione un evento')
            return
        self.db.execute('DELETE FROM EventoDetalle WHERE evento_id=?', (self.evento_id,))
        for r in self.detalle_rows:
            desc = r['combobox'].get().strip()
            if not desc:
                continue
            comida = next((c for c in self.comidas if c['descripcion']==desc), None)
            if not comida:
                continue
            momento = r['momento'].get().strip()
            self.db.execute('INSERT INTO EventoDetalle(evento_id, comida_id, momento) VALUES(?,?,?)', (self.evento_id, comida['id'], momento))
        messagebox.showinfo('OK', 'Detalle guardado')

    def delete_evento(self):
        sel = self.tree.selection()
        if not sel:
            messagebox.showwarning('Aviso', 'Seleccione un evento')
            return
        vals = self.tree.item(sel[0])['values']
        if messagebox.askyesno('Confirmar', f'Eliminar evento {vals[1]}?'):
            self.db.execute('DELETE FROM Eventos WHERE id=?', (vals[0],))
            self.load_eventos()
            self.clear_detalle_ui()

    def imprimir_compras(self):
        # For demo, calculate required purchases aggregating compra details from comidas used in event
        if not hasattr(self, 'evento_id'):
            messagebox.showwarning('Aviso', 'Seleccione un evento')
            return
        # aggregate: for each comida in evento, sum the ComidaDetalle amounts and multiply by number of persons?
        # For simplicity, just list required articles
        rows = self.db.fetchall('SELECT cd.articulo_id, a.nombre, SUM(cd.cant_jov+cd.cant_dor+cd.cant_var) as total FROM EventoDetalle ed JOIN ComidaDetalle cd ON ed.comida_id=cd.comida_id JOIN Articulos a ON cd.articulo_id=a.id WHERE ed.evento_id=? GROUP BY cd.articulo_id', (self.evento_id,))
        out = 'Compras requeridas:\n'
        for r in rows:
            out += f"{r['nombre']}: {r['total']}\n"
        messagebox.showinfo('Compras', out)

    def imprimir_saldo(self):
        # For demo, show total cost estimating price from Articulos and required amounts
        if not hasattr(self, 'evento_id'):
            messagebox.showwarning('Aviso', 'Seleccione un evento')
            return
        rows = self.db.fetchall('SELECT cd.articulo_id, a.nombre, SUM(cd.cant_jov+cd.cant_dor+cd.cant_var) as total, a.precio FROM EventoDetalle ed JOIN ComidaDetalle cd ON ed.comida_id=cd.comida_id JOIN Articulos a ON cd.articulo_id=a.id WHERE ed.evento_id=? GROUP BY cd.articulo_id', (self.evento_id,))
        total_cost = 0
        out = 'Saldo estimado:\n'
        for r in rows:
            cost = (r['total'] or 0) * (r['precio'] or 0)
            total_cost += cost
            out += f"{r['nombre']}: {r['total']} x {r['precio']} = {cost:.2f}\n"
        out += f"\nTotal: {total_cost:.2f}"
        messagebox.showinfo('Saldo', out)
