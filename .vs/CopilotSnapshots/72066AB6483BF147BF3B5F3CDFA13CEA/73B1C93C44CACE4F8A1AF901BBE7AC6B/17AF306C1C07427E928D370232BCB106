{% extends 'base.html' %}
{% block content %}
<h1>Eventos</h1>
<form method="post" class="row g-2 mb-3">
  <div class="col-md-6"><input name="nombre" class="form-control" placeholder="Nombre" required></div>
  <div class="col-md-3"><input name="cantidad" class="form-control" placeholder="Personas" required></div>
  <div class="col-md-3">
    <select name="tipo" class="form-select" required>
      <option value="">Seleccione tipo</option>
      <option value="Dorcas">Dorcas</option>
      <option value="Varones">Varones</option>
      <option value="Jovenes">Jovenes</option>
    </select>
  </div>
  <div class="col-12"><button class="btn btn-primary">Agregar</button></div>
</form>

<table class="table table-striped">
  <thead><tr><th>ID</th><th>Nombre</th><th>Cantidad</th><th>Tipo</th><th>Acciones</th></tr></thead>
  <tbody>
    {% for d in datos %}
    <tr>
      <td>{{ d.id }}</td>
      <td>{{ d.nombre }}</td>
      <td>{{ d.cantidad_personas if 'cantidad_personas' in d else '' }}</td>
      <td>{{ d.tipo_actividad if 'tipo_actividad' in d else '' }}</td>
      <td>
        <a class="btn btn-sm btn-outline-primary" href="/eventos/reporte_compras/{{ d.id }}">Reporte Compras</a>
        <a class="btn btn-sm btn-outline-secondary" href="/eventos/reporte_saldo/{{ d.id }}">Reporte Saldo</a>
        <a class="btn btn-sm btn-outline-success" href="/tesoreria/reporte_balance/{{ d.id }}">Reporte Tesorería</a>
        <a class="btn btn-sm btn-outline-info" href="/eventos/{{ d.id }}">Detalle</a>
        {% if d.closed %}
          <a class="btn btn-sm btn-warning" href="/eventos/{{ d.id }}/toggle_closed">Abrir evento</a>
        {% else %}
          <a class="btn btn-sm btn-danger" href="/eventos/{{ d.id }}/toggle_closed">Cerrar evento</a>
        {% endif %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>

{% endblock %}
