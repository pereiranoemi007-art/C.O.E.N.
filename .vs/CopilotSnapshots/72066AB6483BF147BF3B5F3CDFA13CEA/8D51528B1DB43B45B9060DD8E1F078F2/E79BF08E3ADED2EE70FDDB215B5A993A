<h2>Comidas</h2>

<!-- AGREGAR COMIDA -->
<form method="post" action="/add_comida">
    <div style="display:flex; gap:10px; margin-bottom:10px;">
        <input name="descripcion" placeholder="Descripción" style="flex:1;">
        <button>Agregar Comida</button>
    </div>
</form>

<hr>

<div style="display:flex; gap:20px;">

    <!-- IZQUIERDA: TABLA -->
    <div style="width:40%;">
        <table border="1" width="100%">
            <tr>
                <th>ID</th>
                <th>Descripción</th>
                <th></th>
            </tr>

            {% for c in comidas %}
            <tr 
                onclick="window.location.href='/comidas?id={{c.id}}'"
                style="cursor:pointer; {% if comida_id and comida_id|string == c.id|string %}background:#ddd;{% endif %}"
            >
                <td>{{c.id}}</td>
                <td>{{c.descripcion}}</td>
                <td>
                    <a href="/eliminar_comida/{{c.id}}" onclick="event.stopPropagation()">X</a>
                </td>
            </tr>
            {% endfor %}
        </table>
    </div>

    <!-- DERECHA: DETALLE -->
    <div style="flex:1;">
        <h4>Detalle de comida</h4>

        <form method="post" action="/guardar_detalle">
            <input type="hidden" name="comida_id" value="{{comida_id}}">

            <!-- ENCABEZADO -->
            <div style="display:flex; gap:25px; font-weight:bold;">
                <div style="flex:1;">Artículo</div>
                <div>Jovenes</div>
                <div>Dorcas</div>
                <div>Varones</div>
                <div></div>
            </div>

            <!-- FILAS -->
            <div id="filas">

            {% for d in detalle %}
            <div style="display:flex; gap:10px; margin-top:5px;">
                
                <select name="articulo" style="flex:1;">
                    {% for a in articulos %}
                    <option value="{{a.nombre}}" {% if a.nombre == d.nombre %}selected{% endif %}>
                        {{a.nombre}}
                    </option>
                    {% endfor %}
                </select>

                <input name="jov" value="{{d.cant_jov}}" style="width:60px;">
                <input name="dor" value="{{d.cant_dor}}" style="width:60px;">
                <input name="var" value="{{d.cant_var}}" style="width:60px;">
                <button type="button" onclick="eliminar(this)">X</button>
            </div>
            {% endfor %}

            </div>

            <br>
            <button type="button" onclick="add()">Agregar fila</button>
            <br><br>

            <button>Guardar detalle</button>
        </form>
    </div>

</div>

<script>
function add(){
    let html = `
    <div style="display:flex; gap:10px; margin-top:5px;">
        <select name="articulo" style="flex:1;">
            {% for a in articulos %}
            <option value="{{a.nombre}}">{{a.nombre}}</option>
            {% endfor %}
        </select>

        <input name="jov" style="width:60px;">
        <input name="dor" style="width:60px;">
        <input name="var" style="width:60px;">
        <button type="button" onclick="eliminar(this)">X</button>
    </div>`;

    document.getElementById("filas").insertAdjacentHTML('beforeend', html)
}

function eliminar(btn){
    btn.parentElement.remove()
}
</script>