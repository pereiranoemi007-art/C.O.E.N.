<!DOCTYPE html>
<html>
<head>
    <title>Compras</title>
</head>
<body>

<h1>Compras</h1>

<!-- MENSAJE -->
{% with messages = get_flashed_messages() %}
  {% if messages %}
    <div style="background: #d4edda; padding:10px;">
      {% for m in messages %}
        {{ m }}
      {% endfor %}
    </div>
  {% endif %}
{% endwith %}

<form method="post">

    <!-- EVENTO -->
    <label>Evento:</label>
    <select name="evento" required onchange="habilitarFormulario()" id="evento">
        <option value="">Seleccione evento</option>
        {% for e in eventos %}
        <option value="{{ e.id }}">{{ e.nombre }}</option>
        {% endfor %}
    </select>

    <br><br>

    <!-- FILAS -->
    <div id="filas"></div>

    <button type="button" onclick="agregarFila()" id="btnAgregar" disabled>
        Agregar fila
    </button>

    <br><br>

    <button type="submit" id="btnGuardar" disabled>
        Guardar
    </button>

</form>

<hr>

<h2>Compras guardadas</h2>

<table border="1">
    <tr>
        <th>ID</th>
        <th>Artículo</th>
        <th>Cantidad</th>
        <th>Total</th>
    </tr>

    {% for d in datos %}
    <tr>
        <td>{{ d.id }}</td>
        <td>{{ d.articulo }}</td>
        <td>{{ d.cantidad }}</td>
        <td>{{ d.precio_total }}</td>
    </tr>
    {% endfor %}
</table>

<script>
const articulos = {{ articulos | tojson }}

function habilitarFormulario() {
    let evento = document.getElementById("evento").value

    if (evento !== "") {
        document.getElementById("btnAgregar").disabled = false
        document.getElementById("btnGuardar").disabled = false

        if (document.querySelectorAll(".fila").length === 0) {
            agregarFila()
        }
    }
}

function agregarFila() {
    let options = '<option value="">Seleccione artículo</option>'
    options += articulos.map(a => 
        `<option value="${a.id}">${a.nombre}</option>`
    ).join('')

    let html = `
    <div class="fila" style="margin-bottom:10px;">
        <select name="articulo" required>
            ${options}
        </select>

        <input type="number" name="cantidad" placeholder="Cantidad" required>
        <input type="number" name="precio" placeholder="Precio" required>

        <button type="button" onclick="eliminarFila(this)">Eliminar</button>
    </div>
    `

    document.getElementById("filas").insertAdjacentHTML('beforeend', html)
}

function eliminarFila(btn) {
    btn.parentElement.remove()
}
</script>

</body>
</html>