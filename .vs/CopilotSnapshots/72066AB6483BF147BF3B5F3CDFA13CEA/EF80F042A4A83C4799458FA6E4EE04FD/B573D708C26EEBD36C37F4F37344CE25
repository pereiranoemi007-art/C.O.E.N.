{% extends 'base.html' %}
{% block content %}
<h1>Evento: {{ evento.nombre }}</h1>
<p>Personas: {{ evento.cantidad_personas }} - Tipo: {{ evento.tipo_actividad }} - {% if evento.closed %}CERRADO{% else %}ABIERTO{% endif %}</p>

<div class="row">
  <div class="col-md-6">
    <h4>Comidas disponibles</h4>
    <form method="post" action="/eventos/{{ evento.id }}/add_comida">
      <div class="input-group mb-3">
        <select name="comida_id" class="form-select" {% if evento.closed %} disabled {% endif %}>
          <option value="">Seleccione comida</option>
          {% for c in comidas %}
          <option value="{{ c.id }}">{{ c.descripcion }}</option>
          {% endfor %}
        </select>
        <button class="btn btn-primary" type="submit" {% if evento.closed %} disabled {% endif %}>Agregar a evento</button>
      </div>
    </form>
  </div>

  <div class="col-md-6">
    <h4>Comidas vinculadas</h4>
    <table class="table table-sm">
      <thead><tr><th>ID</th><th>Comida</th><th></th></tr></thead>
      <tbody>
        {% for v in vinculadas %}
        <tr>
          <td>{{ v.comida_id }}</td>
          <td>{{ v.descripcion }}</td>
          <td>
            <a class="btn btn-sm btn-danger" href="/eventos/{{ evento.id }}/remove_comida/{{ v.detalle_id }}" {% if evento.closed %} onclick="alert('Evento cerrado'); return false;" {% endif %}>Quitar</a>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

{% endblock %}