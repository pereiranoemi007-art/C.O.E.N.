<h1>Eventos</h1>

<form method="post">
    <input name="nombre" placeholder="Nombre">
    <input name="cantidad" placeholder="Personas">
    <input name="tipo" placeholder="Tipo">
    <button>Agregar</button>
</form>

<table border="1">
<tr><th>ID</th><th>Nombre</th></tr>

{% for e in datos %}
<tr>
<td>{{e.id}}</td>
<td>{{e.nombre}}</td>
</tr>
{% endfor %}
</table>

<a href="/">Volver</a>